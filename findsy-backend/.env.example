# Copy this file to .env and fill in real values before starting the server.
# Never commit your real .env file.

# Server
PORT=4000
NODE_ENV=production

# Comma-separated list of origins allowed to call this API (your frontend URL(s))
CORS_ORIGIN=http://localhost:3000,http://localhost:5500

# Admin login
# Generate a bcrypt hash for your real passcode with:
#   node -e "console.log(require('bcryptjs').hashSync('your-real-passcode', 10))"
# Do NOT store the plaintext passcode here.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$replace.this.with.a.real.bcrypt.hash.................

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=12h

# SQLite database file path
DB_PATH=./db/findsy.sqlite

# Upload limits
MAX_UPLOAD_MB=5
